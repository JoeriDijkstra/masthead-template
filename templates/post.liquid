<article class="post">
  <header>
    <h1>{{ post.title | escape }}</h1>
    {% if post.published_at %}
      <time datetime="{{ post.published_at | iso8601 }}">{{ post.published_at | strftime: "%B %-d, %Y" }}</time>
    {% endif %}
  </header>
  <div class="post-body">
    {{ body_html }}
  </div>
  <footer><a href="/">&larr; Back to {{ site.name | escape }}</a></footer>
</article>
